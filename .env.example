# Solana RPC endpoints
EXPO_PUBLIC_DEVNET_RPC_URL=https://api.devnet.solana.com
EXPO_PUBLIC_MAINNET_RPC_URL=

# Mobile Wallet Adapter app identity shown inside the wallet popup
EXPO_PUBLIC_APP_NAME=CyberCard Arena
EXPO_PUBLIC_APP_URI=https://cybercard.arena
EXPO_PUBLIC_APP_ICON=favicon.ico

# Supabase (filled after project creation)
EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
